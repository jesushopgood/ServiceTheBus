{
  "ConnectionStrings": {
    "OrderServiceDb": "Host=localhost;Port=5432;Database=orderservice;Username=postgres;Password=postgres"
  },
  "AzureServiceBus": {
    "ConnectionString": "Endpoint=sb://sb-servicethebus.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<replace-me>",
    "TopicName": "orders-topic",
    "SupplierQuotesQueueName": "supplier-quotes",
    "TransportType": "AmqpTcp",
    "Retry": {
      "MaxRetries": 3,
      "DelayMs": 800,
      "TryTimeoutSeconds": 30
    }
  },
  "MessageQueue": {
    "UseLocal": true,
    "SupplierCodes": [ "ENG", "SCO", "WAL" ]
  },
  "MessageProcessing": {
    "Mode": "Service"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
