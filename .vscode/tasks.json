{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build OrderService.Api",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/OrderService/OrderService.Api/OrderService.Api.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run OrderService.Api",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/OrderService/OrderService.Api/OrderService.Api.csproj"
      ],
      "dependsOn": "build OrderService.Api",
      "problemMatcher": "$msCompile"
    }
  ]
}
